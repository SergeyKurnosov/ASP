@page "/bin_hex"
@rendermode InteractiveServer
@implements IHandleEvent

<PageTitle>Bin_Hex:</PageTitle>

<h3>Bin_Hex</h3>

<!-- From Uiverse.io by andrew-demchenk0 -->
<div class="wrapper">
    <div class="card-switch">
        <label class="switch">
            <input type="checkbox" class="toggle">
            <span class="slider"></span>
            <span class="card-side"></span>
            <div class="flip-card__inner">
                <div class="flip-card__front">
                    <div class="title">Hex to Bin</div>
                    <form class="flip-card__form" action="" @onsubmit="HexToBin">
                        <input class="flip-card__input" placeholder="hexadecimal" type="text" @bind=hex>
                        <input class="flip-card__input" placeholder="binary" type="text" readonly @bind=bin >
                        <button type="submit" class="flip-card__btn" >Let`s go!</button>
                    </form>
                </div>
                <div class="flip-card__back">
                    <div class="title">Bin to Hex</div>
                    <form class="flip-card__form" action="" @onsubmit="BinToHex">
                        <input class="flip-card__input" placeholder="binary" type="text" @bind=bin>
                        <input class="flip-card__input" placeholder="hexadecimal" type="text" readonly @bind=hex>
                        <button type="submit" class="flip-card__btn">Let`s go!</button>
                    </form>
                </div>
            </div>
        </label>
    </div>
</div>

