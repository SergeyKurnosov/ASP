<!DOCTYPE html>
<html lang="en" id="main_HTML" data-bs-theme="">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<base href="/" />
	<link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
	<link rel="stylesheet" href="app.css" />
	<link rel="stylesheet" href="Movies.styles.css" />
	<link rel="icon" type="image/png" href="favicon.png" />
	<HeadOutlet />
</head>


<body>
	<button autofocus id="btn-changed-theme" style="position:absolute;z-index:2;margin-left:90%;border:none">
		<img id="img-changed-theme" src="images/darth-mauls-lightsaber_87100.png" alt="" style="background-color:transparent" />
	</button>
	<Routes />
	<script src="_framework/blazor.web.js"></script>
</body>

<script>
	 let is_dark = false
	document.getElementById("img-changed-theme").setAttribute('src', is_dark ? "images/obi-wans-lightsaber_87091.png" : "images/darth-mauls-lightsaber_87100.png");
	document.getElementById("btn-changed-theme").addEventListener('click', function() {
    is_dark = !is_dark;
	document.getElementById("main_HTML").setAttribute('data-bs-theme', is_dark ? "dark" : "light");
	document.getElementById("img-changed-theme").setAttribute('src', is_dark ? "images/obi-wans-lightsaber_87091.png" : "images/darth-mauls-lightsaber_87100.png");
	});
</script>

</html>

