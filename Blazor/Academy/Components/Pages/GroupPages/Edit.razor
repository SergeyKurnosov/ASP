@page "/groups/edit"
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Group</h2>
<hr />
@if (Group is null)
{
	<p><em>Loading...</em></p>
}
else
{
	<div class="row">
		<div class="col-md-4">
			<EditForm method="post" Model="Group" OnValidSubmit="UpdateGroup" FormName="edit" Enhance>
				<DataAnnotationsValidator />
				<ValidationSummary role="alert" />
				<input type="hidden" name="Group.group_id" value="@Group.group_id" />
@* 				<div class="mb-3">
					<label for="group_name" class="form-label">group_name:</label>
					<InputText id="group_name" @bind-Value="Group.group_name" class="form-control" />
					<ValidationMessage For="() => Group.group_name" class="text-danger" />
				</div> *@
@* 				<div class="mb-3">

					 					<div class="form-group">
						<label class="control-label"></label>
						<InputNumber id="direction" class="form-control" list="payeenames" @bind-Value="Direction" />
						<ValidationMessage For="() => Group.direction" class="text-danger" />
						<datalist id="payeenames" >
							@foreach (var item in @directions)
							{
								<option value="@item.Key">@item.Value</option>
							}
						</datalist>
					</div>  *@
@* 
				</div>
				<div class="mb-3">
					<label for="learning_days" class="form-label">learning_days:</label>
					<InputNumber id="learning_days" @bind-Value="LearningDays" class="form-control" />
					<ValidationMessage For="() => Group.learning_days" class="text-danger" />
				</div> *@
@* 				<div class="mb-3">
					<label for="start_time" class="form-label">start_time:</label>
					<input type="time" id="start_time" @bind="Group.start_time" class="form-control" />
					<ValidationMessage For="() => Group.start_time" class="text-danger" />
				</div> *@
				<button type="submit" class="btn btn-primary">Save</button>
			</EditForm>
		</div>
	</div>
}

<div>
	<a href="/groups">Back to List</a>
</div>

@code {
	[SupplyParameterFromQuery]
	private int group_id { get; set; }

	[SupplyParameterFromForm]
	private Group? Group { get; set; }

	int direction;
	public int Direction
	{
		get => Group.direction;
		set => Group.direction = Convert.ToByte(direction = value);
	}

	List<KeyValuePair<int, string>> directions = new List<KeyValuePair<int, string>>();


	int learning_days;
	int LearningDays
	{
		get => Group.learning_days;
		set => Group.learning_days = (byte)(learning_days = value);
	}

	protected override async Task OnInitializedAsync()
	{

		using var context = DbFactory.CreateDbContext();
		Group ??= await context.Groups.FirstOrDefaultAsync(m => m.group_id == group_id);


		if (Group is null)
		{
			NavigationManager.NavigateTo("notfound");
		}
		Direction = Group.direction;
		LearningDays = Group.learning_days;

		using (Academy.Data.AcademyContext contextDir = DbFactory.CreateDbContext())
		{
			await foreach (var item in contextDir.Directions)
			{
				directions.Add(new KeyValuePair<int, string>((int)item.direction_id, item.direction_name));
			}

			directions.Sort((x,y) => x.Key.CompareTo(y.Key));
		}

	}

	// To protect from overposting attacks, enable the specific properties you want to bind to.
	// For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
	private async Task UpdateGroup()
	{
		using var context = DbFactory.CreateDbContext();
		context.Attach(Group!).State = EntityState.Modified;

		try
		{
			await context.SaveChangesAsync();
		}
		catch (DbUpdateConcurrencyException)
		{
			if (!GroupExists(Group!.group_id))
			{
				NavigationManager.NavigateTo("notfound");
			}
			else
			{
				throw;
			}
		}

		NavigationManager.NavigateTo("/groups");
	}

	private bool GroupExists(int group_id)
	{
		using var context = DbFactory.CreateDbContext();
		return context.Groups.Any(e => e.group_id == group_id);
	}
}
