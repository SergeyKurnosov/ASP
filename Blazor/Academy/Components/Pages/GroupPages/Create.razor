@page "/groups/create"
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Group</h2>
<hr />
<div class="row">
	<div class="col-md-4">
		<EditForm method="post" Model="Group" OnValidSubmit="AddGroup" FormName="create" Enhance>
			<DataAnnotationsValidator />
			<ValidationSummary class="text-danger" role="alert" />

			<div class="mb-3">
				<label for="group_id" class="form-label">ID:</label>
				<InputNumber id="group_id" @bind-Value="ID" class="form-control" />
				<ValidationMessage For="() => Group.group_id" class="text-danger" />
			</div>

			<div class="mb-3">
				<label for="group_name" class="form-label">group_name:</label>
				<InputText id="group_name" @bind-Value="Group.group_name" class="form-control" />
				<ValidationMessage For="() => Group.group_name" class="text-danger" />
			</div>
			<div class="mb-3">
				@* 					<label for="direction" class="form-label">direction:</label>
					<InputNumber id="direction" @bind-Value="Direction" class="form-control" />
					<ValidationMessage For="() => Group.direction" class="text-danger" /> *@
				<div class="form-group">
					<label class="control-label"></label>
					<InputNumber id="direction" class="form-control" list="payeenames" @bind-Value="Direction" />
					<ValidationMessage For="() => Group.direction" class="text-danger" />
					<datalist id="payeenames">
						@foreach (var item in @directions)
						{
							<option value="@item.Key">@item.Value</option>
						}
					</datalist>
				</div>

			</div>

			<div class="mb-3">
				<label for="learning_days" class="form-label">learning_days:</label>
				<InputNumber id="learning_days" @bind-Value="LearningDays" class="form-control" />
				<ValidationMessage For="() => Group.learning_days" class="text-danger" />
			</div>

			<div class="mb-3">
				<label for="start_time" class="form-label">start_time:</label>
				<input type="time" id="start_time" @bind="Group.start_time" class="form-control" />
				<ValidationMessage For="() => Group.start_time" class="text-danger" />
			</div>
			<button type="submit" class="btn btn-primary">Create</button>
		</EditForm>
	</div>
</div>

<div>
	<a href="/groups">Back to List</a>
</div>

@code {
	[SupplyParameterFromForm]
	private Group Group { get; set; } = new();

	int direction;
	public int Direction
	{
		get => Group.direction;
		set => Group.direction = Convert.ToByte(direction = value);
	}

	List<KeyValuePair<int, string>> directions = new List<KeyValuePair<int, string>>();


	int learning_days;
	int LearningDays
	{
		get => Group.learning_days;
		set => Group.learning_days = (byte)(learning_days = value);
	}

	int id;
	int ID
	{
		get => Group.group_id;
		set =>
		Group.group_id = (byte)(id = value);
	}

	protected override void OnInitialized()
	{
		Direction = Group.direction;
		LearningDays = Group.learning_days;

		using (Academy.Data.AcademyContext contextDir = DbFactory.CreateDbContext())
		{
			foreach (var item in contextDir.Directions)
			{
				directions.Add(new KeyValuePair<int, string>((int)item.direction_id, item.direction_name));
			}
			ID = contextDir.Groups.Max(g => g.group_id) + 1;


			directions.Sort((x, y) => x.Key.CompareTo(y.Key));
		}
	}

	// To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
	private async Task AddGroup()
	{
		using var context = DbFactory.CreateDbContext();
		context.Groups.Add(Group);
		await context.SaveChangesAsync();
		NavigationManager.NavigateTo("/groups");
	}
}
